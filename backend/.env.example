# TeamOne Backend Services - Environment Configuration
# Copy this to each service folder as .env

# Service Configuration
NODE_ENV=development
PORT=3002

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/teamone

# Redis
REDIS_URL=redis://localhost:6379

# JWT (Change in production!)
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRY=15m
REFRESH_TOKEN_SECRET=dev-refresh-secret-change-in-production
REFRESH_TOKEN_EXPIRY=7d

# Google OAuth (Optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
